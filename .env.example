PORT=5000
NODE_ENV=development
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gymvault
JWT_SECRET=replace_with_long_random_secret
APP_SECRET_ENC_KEY=replace_with_32_plus_char_random_secret
MASTER_PASSWORD=replace_with_superadmin_password
SUPERADMIN_ALLOWED_IPS=
TRUST_PROXY=false
SERVER_URL=http://localhost:5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
PUBLIC_FRONTEND_URL=
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
RUN_DB_INIT_ON_BOOT=true
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Set this to email after SMTP is configured if you want password reset OTP over email.
PASSWORD_RESET_DELIVERY_MODE=preview
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=GymVault
SMTP_FROM_EMAIL=
# If you use email OTP for owner/staff login, you can leave MSG91 OTP values empty.
MSG91_AUTH_KEY=
MSG91_OTP_AUTH_KEY=
MSG91_WHATSAPP_AUTH_KEY=
MSG91_OTP_MODE=preview
MSG91_OWNER_LOGIN_OTP_MODE=preview
MSG91_OTP_TEMPLATE_ID=
MSG91_OWNER_LOGIN_OTP_TEMPLATE_ID=
MSG91_PORTAL_SIGNIN_URL=https://control.msg91.com/signin/
MSG91_WHATSAPP_ONBOARDING_URL=
MSG91_WHATSAPP_GUIDE_URL=https://msg91.com/help/whatsapp/whatsapp-number-integration---onboarding
MSG91_META_BUSINESS_URL=https://business.facebook.com/
MSG91_WHATSAPP_SUPPORT_URL=https://calendly.com/onbording-msg91/20-min-onbording
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PARTNER_CONNECT_BASE_URL=
RAZORPAY_PARTNER_CLIENT_ID=
RAZORPAY_PARTNER_CLIENT_SECRET=
RAZORPAY_PARTNER_REDIRECT_URI=
RAZORPAY_PARTNER_STATE_TTL_SECONDS=600
RAZORPAY_PLATFORM_FEE_PERCENT=0
# Keep Twilio only if you still want member OTP fallback during transition.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1xxxxxxxxxx

# Optional smoke test overrides
SMOKE_BASE_URL=http://localhost:5000
SMOKE_FRONTEND_URL=https://gymvault.tech
SMOKE_BACKEND_URL=https://gym-management-system-4nfu.onrender.com
SMOKE_OWNER_EMAIL=
SMOKE_OWNER_TOKEN=
